POSTGRES_USER=webhook_user
POSTGRES_PASSWORD=webhook_password
POSTGRES_PORT=5432
POSTGRES_DB=webhook_db
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
WORKER_COUNT=10
BATCH_SIZE=100
INITIAL_TIMEOUT=10
MAX_RETRIES=5
POLL_INTERVAL=1.5
DLQ_RETENTION_DAYS=30